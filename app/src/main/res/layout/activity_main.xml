<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape split layout: video + controls on the left, live stats on the
     right, so everything (incl. FPS / dropped / decoder) fits on one screen
     without scrolling. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- ===== Left column: controls + video ===== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <Spinner
            android:id="@+id/presetSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- URL + Play/Stop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/urlInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="http://xxx/live.ts"
                android:inputType="textUri"
                android:maxLines="1"
                android:scrollHorizontally="true"
                android:textSize="13sp" />

            <Button
                android:id="@+id/playBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:minWidth="60dp"
                android:text="Play" />

            <Button
                android:id="@+id/stopBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:minWidth="60dp"
                android:text="Stop" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/forceSoftware"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Soft Decode"
            android:textSize="13sp" />

        <!-- Player: left main body -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:background="#FF000000"
            app:resize_mode="fit"
            app:surface_type="surface_view"
            app:use_controller="false" />

        <!-- Collapsible playurl config + export, under the video -->
        <TextView
            android:id="@+id/advancedToggle"
            style="@style/SectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@color/panel_bg"
            android:padding="6dp"
            android:text="playurl Config  [+]" />

        <LinearLayout
            android:id="@+id/configContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <Button
            android:id="@+id/getUrlBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:text="Get URL" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/exportLogBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Export Log" />

            <Button
                android:id="@+id/exportReportBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Export Report" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== Right column: live stats ===== -->
    <ScrollView
        android:id="@+id/statsScroll"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_weight="2"
        android:background="@color/panel_bg">

        <TextView
            android:id="@+id/statsView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:textSize="15sp"
            android:textIsSelectable="true" />
    </ScrollView>

</LinearLayout>
