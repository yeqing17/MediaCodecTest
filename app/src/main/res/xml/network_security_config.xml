<?xml version="1.0" encoding="utf-8"?>
<!-- ICC playurl and live streams use plain HTTP; allow cleartext for all hosts. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
